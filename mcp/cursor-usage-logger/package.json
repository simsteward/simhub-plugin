{
  "name": "cursor-usage-logger",
  "version": "2.2.0",
  "description": "MCP server that logs Cursor usage to a JSONL file for Grafana/Loki (local)",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "cursor-usage-logger": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc && node dist/index.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.0",
    "zod": "^3.23.0"
  },
  "optionalDependencies": {
    "tiktoken": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  }
}
