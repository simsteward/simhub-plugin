{
  "title": "SimSteward Event Coverage",
  "uid": "simsteward-event-coverage",
  "description": "Event distribution and log volume for the selected time range (e.g. last 7 days). Use to confirm which event types have data before opening topic-specific dashboards.",
  "tags": ["simsteward", "overview", "events"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "templating": {
    "list": [
      {
        "name": "DS_LOKI",
        "type": "datasource",
        "query": "loki",
        "current": { "value": "loki_local", "text": "Loki Local" },
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "refresh": 1,
        "options": [],
        "skipUrlSync": false
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Log volume over time",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 5 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "expr": "sum(count_over_time({app=\"sim-steward\"} [$__interval]))",
          "refId": "A",
          "legendFormat": "logs"
        }
      ]
    },
    {
      "id": 2,
      "type": "table",
      "title": "Event distribution (count by event)",
      "gridPos": { "x": 0, "y": 5, "w": 12, "h": 8 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "expr": "{app=\"sim-steward\"} | json",
          "refId": "A"
        }
      ],
      "transformations": [
        { "id": "extractFields", "options": { "source": "Line", "format": "json" } },
        { "id": "groupBy", "options": { "groupBy": ["event"], "aggregations": [{ "id": "count", "options": {} }] } }
      ]
    },
    {
      "id": 3,
      "type": "table",
      "title": "Component breakdown (count by component)",
      "gridPos": { "x": 12, "y": 5, "w": 12, "h": 8 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "expr": "sum by (component) (count_over_time({app=\"sim-steward\"} [$__range]))",
          "refId": "A",
          "format": "table",
          "instant": true
        }
      ]
    },
    {
      "id": 4,
      "type": "logs",
      "title": "Recent SimSteward logs (sample)",
      "gridPos": { "x": 0, "y": 13, "w": 24, "h": 8 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "options": { "showTime": true, "showLabels": false, "sortOrder": "Descending" },
      "targets": [
        {
          "expr": "{app=\"sim-steward\"} | json",
          "refId": "A"
        }
      ]
    }
  ],
  "time": { "from": "now-7d", "to": "now" }
}
