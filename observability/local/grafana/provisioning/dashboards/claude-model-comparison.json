{
  "id": null,
  "uid": "claude-model-comparison",
  "title": "Claude Code — Model & Effort Comparison",
  "description": "",
  "tags": [
    "claude-code",
    "cost-analysis"
  ],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "time": {
    "from": "now-7d",
    "to": "now"
  },
  "refresh": "1m",
  "schemaVersion": 39,
  "fiscalYearStartMonth": 0,
  "liveNow": false,
  "style": "dark",
  "templating": {
    "list": [
      {
        "name": "project",
        "label": "Project",
        "type": "query",
        "datasource": {
          "type": "loki",
          "uid": "loki_local"
        },
        "query": "{app=\"claude-token-metrics\"} | json",
        "regex": "\"project\":\"([^\"]+)\"",
        "refresh": 2,
        "includeAll": true,
        "allValue": ".*",
        "sort": 1,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
