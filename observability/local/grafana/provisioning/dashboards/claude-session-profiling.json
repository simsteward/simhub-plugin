          "uid": "loki_local"
        },
        "query": "{app=\"claude-token-metrics\"}",
        "regex": "model=\"([^\"]+)\"",
        "refresh": 2,
        "includeAll": true,
        "allValue": ".*",
        "sort": 1,
        "current": {
          "text": "All",
          "value": "$__all"
