{
  "id": null,
  "uid": "claude-session-profiling",
  "title": "Claude Code — Session Profiling",
  "description": "",
  "tags": [
    "claude-code",
    "cost-analysis"
  ],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "time": {
    "from": "now-7d",
    "to": "now"
  },
  "refresh": "1m",
  "schemaVersion": 39,
  "fiscalYearStartMonth": 0,
  "liveNow": false,
  "style": "dark",
  "templating": {
    "list": [
      {
        "name": "model",
        "label": "Model",
        "type": "query",
        "datasource": {
          "type": "loki",
          "uid": "loki_local"
        },
        "query": "{app=\"claude-token-metrics\"} | json",
        "regex": "\"model\":\"([^\"]+)\"",
        "refresh": 2,
        "includeAll": true,
        "allValue": ".*",
        "sort": 1,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "project",
        "label": "Project",
        "type": "query",
        "datasource": {
          "type": "loki",
          "uid": "loki_local"
        },
        "query": "{app=\"claude-token-metrics\"} | json",
        "regex": "\"project\":\"([^\"]+)\"",
        "refresh": 2,
        "includeAll": true,
        "allValue": ".*",
        "sort": 1,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "effort",
        "label": "Effort",
        "type": "query",
        "datasource": {
          "type": "loki",
          "uid": "loki_local"
        },
        "query": "{app=\"claude-token-metrics\"} | json",
        "regex": "\"effort\":\"([^\"]+)\"",
        "refresh": 2,
        "includeAll": true,
        "allValue": ".*",
        "sort": 1,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "🔬 Session Shape",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 1
      }
    },
    {
      "id": 1,
      "title": "Avg Turns / Session",
      "type": "stat",
      "datasource": {
        "type": "loki",
        "uid": "loki_local"
      },
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 5,
        "h": 4
      },
      "transparent": true,
      "fieldConfig": {
        "defaults": {
          "noValue": "0",
          "unit": "short",
          "decimals": 0,
          "color": {
            "mode": "fixed",
            "fixedColor": "#73BF69"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "#73BF69"
              }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "horizontal",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki_local"
          },
          "expr": "sum(sum_over_time({app=\"claude-token-metrics\", model=~\"$model\", project=~\"$project\", effort=~\"$effort\"} | json assistant_turns | unwrap assistant_turns [$__range])) / count(count_over_time({app=\"claude-token-metrics\", model=~\"$model\", project=~\"$project\", effort=~\"$effort\"} [$__range]))",
          "legendFormat": "",
          "queryType": "range",
          "refId": "A"
        }
      ]
    },
