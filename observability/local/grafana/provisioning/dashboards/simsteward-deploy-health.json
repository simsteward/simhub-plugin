        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki_local" },
          "editorMode": "code",
          "expr": "{app=\"sim-steward\", env=\"${env}\"} | json | event=\"deploy_marker\"",
          "queryType": "range",
          "refId": "A"
        }
      ],
