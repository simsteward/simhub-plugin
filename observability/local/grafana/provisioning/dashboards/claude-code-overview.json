    {
      "id": 8,
      "title": "Hook Type Breakdown",
      "description": "% share of each hook type across all events.",
      "type": "table",
      "transparent": true,
      "gridPos": {
        "x": 8,
        "y": 19,
        "w": 8,
        "h": 10
