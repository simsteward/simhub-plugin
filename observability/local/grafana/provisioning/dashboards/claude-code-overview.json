        "frameIndex": 0,
        "showHeader": false,
        "cellHeight": "sm",
        "footer": {
          "show": false,
          "reducer": [
            "sum"
          ],
          "fields": ""
        },
        "sortBy": [
          {
            "desc": true,
            "displayName": "Last *"
