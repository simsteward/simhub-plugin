      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "custom": {
            "inspect": false,
            "width": 0
          },
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": [
