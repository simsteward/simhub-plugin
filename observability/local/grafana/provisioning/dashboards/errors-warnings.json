{
  "title": "SimSteward Errors & Warnings",
  "uid": "simsteward-errors-warnings",
  "description": "All ERROR and WARN logs across components with rate and level filter.",
  "tags": ["simsteward", "health", "errors"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "ERROR rate",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 4 },
      "datasource": { "type": "loki", "uid": "loki_local" },
      "targets": [
        {
          "expr": "sum(count_over_time({app=\"sim-steward\", level=\"ERROR\"} [$__interval]))",
          "refId": "A",
          "legendFormat": "errors"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "WARN rate",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 4 },
      "datasource": { "type": "loki", "uid": "loki_local" },
      "targets": [
        {
          "expr": "sum(count_over_time({app=\"sim-steward\", level=\"WARN\"} [$__interval]))",
          "refId": "A",
          "legendFormat": "warns"
        }
      ]
    },
    {
      "id": 3,
      "type": "logs",
      "title": "ERROR logs",
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki_local" },
      "options": { "showTime": true, "showLabels": false, "sortOrder": "Descending" },
      "targets": [
        {
          "expr": "{app=\"sim-steward\", level=\"ERROR\"}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "logs",
      "title": "WARN logs",
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki_local" },
      "options": { "showTime": true, "showLabels": false, "sortOrder": "Descending" },
      "targets": [
        {
          "expr": "{app=\"sim-steward\", level=\"WARN\"}",
          "refId": "A"
        }
      ]
    }
  ],
  "time": { "from": "now-7d", "to": "now" }
}
