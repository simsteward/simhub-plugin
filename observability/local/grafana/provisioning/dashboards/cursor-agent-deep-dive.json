{
  "title": "Cursor Agent Deep Dive",
  "uid": "cursor-agent-deep-dive",
  "description": "Deep dive into Cursor agent activity using rich RPC data.",
  "tags": ["cursor", "usage", "agent", "mcp", "rpc", "contextstream"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "editable": true,
  "panels": [
    {
      "id": 1,
      "type": "logs",
      "title": "User Requests",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki_local" },
      "options": { "showTime": true, "showLabels": false, "sortOrder": "Descending" },
      "targets": [
        {
          "expr": "{app=\"cursor-usage\", env=\"local\"} | json | event=\"user_request\"",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "logs",
      "title": "Agent Responses",
      "gridPos": { "x": 0, "y": 8, "w": 24, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki_local" },
      "options": { "showTime": true, "showLabels": false, "sortOrder": "Descending" },
      "targets": [
        {
          "expr": "{app=\"cursor-usage\", env=\"local\"} | json | event=\"agent_response\"",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "logs",
      "title": "Tool Results",
      "gridPos": { "x": 0, "y": 16, "w": 24, "h": 12 },
      "datasource": { "type": "loki", "uid": "loki_local" },
      "options": { "showTime": true, "showLabels": false, "sortOrder": "Descending" },
      "targets": [
        {
          "expr": "{app=\"cursor-usage\", env=\"local\"} | json | event=\"tool_result_logged\"",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "logs",
      "title": "Tool Errors",
      "gridPos": { "x": 0, "y": 28, "w": 24, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki_local" },
      "options": { "showTime": true, "showLabels": false, "sortOrder": "Descending" },
      "targets": [
        {
          "expr": "{app=\"cursor-usage\", env=\"local\"} | json | event=\"tool_result_logged\" | error != ``",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "ContextStream calls over time (by tool)",
      "gridPos": { "x": 0, "y": 36, "w": 12, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki_local" },
      "targets": [
        {
          "expr": "sum by (cs_tool) (count_over_time({app=\"cursor-usage\", env=\"local\"} | json | event=\"contextstream_usage\" [$__interval]))",
          "refId": "A",
          "legendFormat": "{{cs_tool}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "ContextStream op cost over time",
      "gridPos": { "x": 12, "y": 36, "w": 12, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki_local" },
      "targets": [
        {
          "expr": "sum(sum_over_time({app=\"cursor-usage\", env=\"local\"} | json | event=\"contextstream_usage\" | unwrap op_cost [$__interval]))",
          "refId": "A",
          "legendFormat": "ops"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [
            { "value": null, "color": "green" },
            { "value": 5000, "color": "yellow" },
            { "value": 25000, "color": "orange" }
          ]}
        }
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "ContextStream tokens in/out over time",
      "gridPos": { "x": 0, "y": 44, "w": 12, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki_local" },
      "targets": [
        {
          "expr": "sum(sum_over_time({app=\"cursor-usage\", env=\"local\"} | json | event=\"contextstream_usage\" | unwrap input_tokens [$__interval]))",
          "refId": "A",
          "legendFormat": "tokens in"
        },
        {
          "expr": "sum(sum_over_time({app=\"cursor-usage\", env=\"local\"} | json | event=\"contextstream_usage\" | unwrap output_tokens [$__interval]))",
          "refId": "B",
          "legendFormat": "tokens out"
        }
      ]
    },
    {
      "id": 8,
      "type": "stat",
      "title": "ContextStream errors / total calls",
      "gridPos": { "x": 12, "y": 44, "w": 6, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki_local" },
      "targets": [
        {
          "expr": "sum(count_over_time({app=\"cursor-usage\", env=\"local\"} | json | event=\"contextstream_usage\" | has_error=\"true\" [$__range]))",
          "refId": "A",
          "legendFormat": "errors"
        },
        {
          "expr": "sum(count_over_time({app=\"cursor-usage\", env=\"local\"} | json | event=\"contextstream_usage\" [$__range]))",
          "refId": "B",
          "legendFormat": "total"
        }
      ],
      "options": { "graphMode": "none", "colorMode": "value" },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [
            { "value": null, "color": "green" }
          ]}
        }
      }
    },
    {
      "id": 9,
      "type": "gauge",
      "title": "ContextStream session op budget (selected range)",
      "gridPos": { "x": 18, "y": 44, "w": 6, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki_local" },
      "targets": [
        {
          "expr": "sum(sum_over_time({app=\"cursor-usage\", env=\"local\"} | json | event=\"contextstream_usage\" | unwrap op_cost [$__range]))",
          "refId": "A"
        }
      ],
      "options": { "showThresholdLabels": true },
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 25000,
          "thresholds": { "mode": "absolute", "steps": [
            { "value": null, "color": "green" },
            { "value": 5000, "color": "yellow" },
            { "value": 25000, "color": "orange" },
            { "value": 100000, "color": "red" }
          ]}
        }
      }
    },
    {
      "id": 10,
      "type": "logs",
      "title": "ContextStream usage (raw)",
      "gridPos": { "x": 0, "y": 52, "w": 24, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki_local" },
      "options": { "showTime": true, "showLabels": false, "sortOrder": "Descending" },
      "targets": [
        {
          "expr": "{app=\"cursor-usage\", env=\"local\"} | json | event=\"contextstream_usage\"",
          "refId": "A"
        }
      ]
    }
  ],
  "time": { "from": "now-1h", "to": "now" }
}
