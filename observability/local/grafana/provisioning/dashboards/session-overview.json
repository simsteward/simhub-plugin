{
  "title": "SimSteward Session Overview",
  "uid": "simsteward-session-overview",
  "description": "Session digests, lifecycle breadcrumbs, and client counts.",
  "tags": ["simsteward", "session", "overview"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "panels": [
    {
      "id": 1,
      "type": "logs",
      "title": "Session digests",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki_local" },
      "options": { "showTime": true, "showLabels": false, "sortOrder": "Descending" },
      "targets": [
        {
          "expr": "{app=\"sim-steward\", component=\"simhub-plugin\"} | json | event = \"session_digest\"",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "logs",
      "title": "Lifecycle events",
      "gridPos": { "x": 0, "y": 8, "w": 24, "h": 6 },
      "datasource": { "type": "loki", "uid": "loki_local" },
      "options": { "showTime": true, "showLabels": false, "sortOrder": "Ascending" },
      "targets": [
        {
          "expr": "{app=\"sim-steward\", component=\"simhub-plugin\"} | json | event =~ \"plugin_started|plugin_ready|iracing_connected|ws_client_connected|iracing_disconnected|plugin_stopped\"",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "logs",
      "title": "WebSocket client events",
      "gridPos": { "x": 0, "y": 14, "w": 24, "h": 6 },
      "datasource": { "type": "loki", "uid": "loki_local" },
      "options": { "showTime": true, "showLabels": false, "sortOrder": "Descending" },
      "targets": [
        {
          "expr": "{app=\"sim-steward\", component=\"bridge\"} | json | event =~ \"ws_client_connected|ws_client_disconnected\"",
          "refId": "A"
        }
      ]
    }
  ],
  "time": { "from": "now-7d", "to": "now" }
}
