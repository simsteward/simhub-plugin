    {
      "id": 11,
      "title": "Per-Turn Token Flow",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 33, "w": 12, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki_local" },
