          "legendFormat": "Output Tokens",
          "queryType": "range"
        },
        {
          "refId": "C",
          "datasource": { "type": "loki", "uid": "loki_local" },
          "expr": "sum(sum_over_time({app=\"claude-dev-logging\", component=\"tokens\"} | json model, project, effort, running_cache_read_tokens | model=~\"$model\" | project=~\"$project\" | effort=~\"$effort\" | unwrap running_cache_read_tokens [$__interval]))",
          "legendFormat": "Cache Read Tokens",
