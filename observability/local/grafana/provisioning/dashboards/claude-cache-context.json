    {
      "id": 10,
      "title": "Avg Turns Before Compaction",
      "type": "stat",
      "gridPos": { "x": 16, "y": 25, "w": 8, "h": 7 },
      "datasource": { "type": "loki", "uid": "loki_local" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki_local" },
          "expr": "sum(count_over_time({app=\"claude-dev-logging\", component=\"tokens\"} | json project | project=~\"$project\" [$__range]))",
