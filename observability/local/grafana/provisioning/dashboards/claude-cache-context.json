    {
      "type": "row",
      "title": "Per-Turn Token Burn",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 32, "w": 24, "h": 1 }
    },
    {
      "id": 11,
      "title": "Per-Turn Token Flow (excl. Cache Read)",
