{
  "title": "SimSteward Command Audit",
  "uid": "simsteward-command-audit",
  "description": "Audit all actions dispatched and their outcomes.",
  "tags": ["simsteward", "command", "audit"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "panels": [
    {
      "id": 1,
      "type": "logs",
      "title": "Action results",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 10 },
      "datasource": { "type": "loki", "uid": "loki_local" },
      "options": { "showTime": true, "showLabels": false, "sortOrder": "Descending" },
      "targets": [
        {
          "expr": "{app=\"sim-steward\", component=\"simhub-plugin\"} | json | event = \"action_result\"",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Failed actions (1h)",
      "gridPos": { "x": 0, "y": 10, "w": 8, "h": 4 },
      "datasource": { "type": "loki", "uid": "loki_local" },
      "options": { "graphMode": "none", "colorMode": "value" },
      "targets": [
        {
          "expr": "count_over_time({app=\"sim-steward\", component=\"simhub-plugin\"} | json | event = \"action_result\" | success = \"false\" [1h])",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Action volume",
      "gridPos": { "x": 8, "y": 10, "w": 16, "h": 4 },
      "datasource": { "type": "loki", "uid": "loki_local" },
      "targets": [
        {
          "expr": "sum(count_over_time({app=\"sim-steward\", component=\"simhub-plugin\"} | json | event = \"action_result\" [$__interval]))",
          "refId": "A",
          "legendFormat": "actions"
        }
      ]
    }
  ],
  "time": { "from": "now-1h", "to": "now" }
}
