{
  "title": "Cursor Usage Analytics",
  "uid": "cursor-usage-analytics",
  "tags": ["cursor", "usage", "analytics", "mcp"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "editable": true,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "panels": [],
      "title": "Performance & Velocity",
      "type": "row"
    },
    {
      "id": 2,
      "title": "Inter-Event Latency (ms)",
      "type": "timeseries",
      "datasource": { "type": "loki", "uid": "loki_local" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "targets": [
        {
          "refId": "A",
          "expr": "quantile_over_time(0.95, {app=\"cursor-usage\", env=\"local\"} | json | unwrap since_last_event_ms [$__interval]) by (session_id)"
        }
      ]
    },
    {
      "id": 3,
      "title": "Max Session Uptime",
      "type": "stat",
      "datasource": { "type": "loki", "uid": "loki_local" },
      "gridPos": { "h": 8, "w": 4, "x": 8, "y": 1 },
      "targets": [
        {
          "refId": "A",
          "expr": "max(max_over_time({app=\"cursor-usage\", env=\"local\"} | json | unwrap session_uptime_ms [$__interval]))"
        }
      ],
      "options": {
        "reduceOptions": { "values": false, "calcs": ["last"], "fields": "" },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": { "unit": "ms" }
      }
    },
    {
      "id": 4,
      "title": "Event Velocity by Type",
      "type": "timeseries",
      "datasource": { "type": "loki", "uid": "loki_local" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (event) (count_over_time({app=\"cursor-usage\", env=\"local\"} | json [$__interval]))"
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "stacking": { "mode": "normal" } } }
      }
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 5,
      "panels": [],
      "title": "Resource & Process Health",
      "type": "row"
    },
    {
      "id": 6,
      "title": "Memory Heap Usage (MB)",
      "type": "timeseries",
      "datasource": { "type": "loki", "uid": "loki_local" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "targets": [
        {
          "refId": "A",
          "expr": "avg_over_time({app=\"cursor-usage\", env=\"local\"} | json | unwrap heap_used_mb [$__interval]) by (session_id)"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "decmbytes" }
      }
    },
    {
      "id": 7,
      "title": "Process Uptime (seconds)",
      "type": "timeseries",
      "datasource": { "type": "loki", "uid": "loki_local" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "targets": [
        {
          "refId": "A",
          "expr": "max_over_time({app=\"cursor-usage\", env=\"local\"} | json | unwrap process_uptime_s [$__interval]) by (session_id)"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 8,
      "panels": [],
      "title": "Environment & Workspace Context",
      "type": "row"
    },
    {
      "id": 9,
      "title": "Active Workspaces",
      "type": "table",
      "datasource": { "type": "loki", "uid": "loki_local" },
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 19 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (workspace_path, git_branch) (count_over_time({app=\"cursor-usage\", env=\"local\"} | json [$__interval]))"
        }
      ]
    },
    {
      "id": 10,
      "title": "Git Dirty",
      "type": "stat",
      "datasource": { "type": "loki", "uid": "loki_local" },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 19 },
      "targets": [
        {
          "refId": "A",
          "expr": "{app=\"cursor-usage\", env=\"local\"} | json | git_dirty = \"true\"",
          "legendFormat": "Dirty"
        }
      ],
      "options": {
        "reduceOptions": { "values": false, "calcs": ["count"], "fields": "" },
        "colorMode": "background"
      }
    },
    {
      "id": 11,
      "title": "Identity",
      "type": "stat",
      "datasource": { "type": "loki", "uid": "loki_local" },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 19 },
      "targets": [
        {
          "refId": "A",
          "expr": "count by (os_platform, os_hostname) (count_over_time({app=\"cursor-usage\", env=\"local\"} | json [$__interval]))"
        }
      ],
      "options": {
        "reduceOptions": { "values": false, "calcs": ["last"], "fields": "" }
      }
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 },
      "id": 12,
      "panels": [],
      "title": "Versions & SDKs",
      "type": "row"
    },
    {
      "id": 13,
      "title": "Stack Overview",
      "type": "table",
      "datasource": { "type": "loki", "uid": "loki_local" },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 28 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (node_version, mcp_server_version, os_release) (count_over_time({app=\"cursor-usage\", env=\"local\"} | json [$__interval]))"
        }
      ]
    },
    {
      "collapsed": true,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 34 },
      "id": 14,
      "panels": [
        {
          "id": 15,
          "title": "All Logs",
          "type": "logs",
          "datasource": { "type": "loki", "uid": "loki_local" },
          "gridPos": { "h": 15, "w": 24, "x": 0, "y": 35 },
          "targets": [
            {
              "refId": "A",
              "expr": "{app=\"cursor-usage\", env=\"local\"}"
            }
          ],
          "options": { "showTime": true, "showLabels": false, "sortOrder": "Descending" }
        }
      ],
      "title": "Logs (Drill-down)",
      "type": "row"
    }
  ],
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "refresh": ""
}
