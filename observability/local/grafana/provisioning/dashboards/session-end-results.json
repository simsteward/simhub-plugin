{
  "title": "SimSteward Session End Results",
  "uid": "simsteward-session-end-results",
  "description": "Chunked session_end_datapoints_results. Filter by session_id in Explore or use the logs below; full results table requires merging chunks by chunk_index (see docs/GRAFANA-LOGGING.md § Chunked session results).",
  "tags": ["simsteward", "session", "results"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "panels": [
    {
      "id": 1,
      "type": "logs",
      "title": "Session end results (all chunks)",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 12 },
      "datasource": { "type": "loki", "uid": "loki_local" },
      "options": { "showTime": true, "showLabels": false, "sortOrder": "Descending" },
      "targets": [
        {
          "expr": "{app=\"sim-steward\", component=\"simhub-plugin\"} | json | event = \"session_end_datapoints_results\"",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Results chunks over time",
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 4 },
      "datasource": { "type": "loki", "uid": "loki_local" },
      "targets": [
        {
          "expr": "sum(count_over_time({app=\"sim-steward\", component=\"simhub-plugin\"} | json | event = \"session_end_datapoints_results\" [$__interval]))",
          "refId": "A",
          "legendFormat": "chunks"
        }
      ]
    }
  ],
  "time": { "from": "now-7d", "to": "now" }
}
