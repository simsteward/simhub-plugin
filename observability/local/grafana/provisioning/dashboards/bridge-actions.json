{
  "title": "SimSteward Bridge & Actions",
  "uid": "simsteward-bridge-actions",
  "description": "Bridge health and action flow: action_received, ws_client_rejected, bridge_start_failed, dashboard_opened.",
  "tags": ["simsteward", "bridge", "actions"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "panels": [
    {
      "id": 1,
      "type": "logs",
      "title": "Action received (bridge)",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki_local" },
      "options": { "showTime": true, "showLabels": false, "sortOrder": "Descending" },
      "targets": [
        {
          "expr": "{app=\"sim-steward\", component=\"bridge\"} | json | event = \"action_received\"",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "logs",
      "title": "Dashboard opened / WS client rejected / bridge start failed",
      "gridPos": { "x": 0, "y": 8, "w": 24, "h": 6 },
      "datasource": { "type": "loki", "uid": "loki_local" },
      "options": { "showTime": true, "showLabels": false, "sortOrder": "Descending" },
      "targets": [
        {
          "expr": "{app=\"sim-steward\"} | json | event =~ \"dashboard_opened|ws_client_rejected|bridge_start_failed\"",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "WS client rejections (24h)",
      "gridPos": { "x": 0, "y": 14, "w": 8, "h": 4 },
      "datasource": { "type": "loki", "uid": "loki_local" },
      "options": { "graphMode": "none", "colorMode": "value" },
      "targets": [
        {
          "expr": "count_over_time({app=\"sim-steward\", component=\"bridge\"} | json | event = \"ws_client_rejected\" [24h])",
          "refId": "A"
        }
      ]
    }
  ],
  "time": { "from": "now-7d", "to": "now" }
}
