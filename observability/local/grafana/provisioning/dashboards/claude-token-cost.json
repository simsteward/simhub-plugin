        "name": "model",
        "label": "Model",
        "type": "query",
        "datasource": {
          "type": "loki",
          "uid": "loki_local"
        },
        "query": "{app=\"claude-token-metrics\"} | json",
        "regex": "\"model\":\"([^\"]+)\"",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "allValue": ".*",
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "sort": 1
      },
      {
        "name": "project",
        "label": "Project",
        "type": "query",
        "datasource": {
          "type": "loki",
          "uid": "loki_local"
        },
        "query": "{app=\"claude-token-metrics\"} | json",
        "regex": "\"project\":\"([^\"]+)\"",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "allValue": ".*",
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "sort": 1
      },
      {
