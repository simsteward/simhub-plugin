        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki_local" },
          "expr": "sum(sum_over_time({app=\"claude-token-metrics\",model=~\"$model\",project=~\"$project\",effort=~\"$effort\"} | json | session_id=~\"$session_id\" | unwrap cost_usd [1d]))",
          "legendFormat": "Daily Cost",
