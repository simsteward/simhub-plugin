{
  "title": "SimSteward Session Capture",
  "uid": "simsteward-session-capture",
  "description": "End-of-session capture success, metadata, and diagnostics (checkered, retry, skipped, mismatch, fingerprint).",
  "tags": ["simsteward", "session", "capture"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "panels": [
    {
      "id": 1,
      "type": "logs",
      "title": "Session summary captured",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 6 },
      "datasource": { "type": "loki", "uid": "loki_local" },
      "options": { "showTime": true, "showLabels": false, "sortOrder": "Descending" },
      "targets": [
        {
          "expr": "{app=\"sim-steward\", component=\"simhub-plugin\"} | json | event = \"session_summary_captured\"",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "logs",
      "title": "Session end datapoints (metadata)",
      "gridPos": { "x": 0, "y": 6, "w": 24, "h": 6 },
      "datasource": { "type": "loki", "uid": "loki_local" },
      "options": { "showTime": true, "showLabels": false, "sortOrder": "Descending" },
      "targets": [
        {
          "expr": "{app=\"sim-steward\", component=\"simhub-plugin\"} | json | event = \"session_end_datapoints_session\"",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "logs",
      "title": "Checkered and retry",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 6 },
      "datasource": { "type": "loki", "uid": "loki_local" },
      "options": { "showTime": true, "showLabels": false, "sortOrder": "Descending" },
      "targets": [
        {
          "expr": "{app=\"sim-steward\", component=\"simhub-plugin\"} | json | event =~ \"checkered_detected|checkered_retry\"",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "logs",
      "title": "Capture skipped / incident mismatch / fingerprint",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 6 },
      "datasource": { "type": "loki", "uid": "loki_local" },
      "options": { "showTime": true, "showLabels": false, "sortOrder": "Descending" },
      "targets": [
        {
          "expr": "{app=\"sim-steward\", component=\"simhub-plugin\"} | json | event =~ \"session_capture_skipped|session_capture_incident_mismatch|session_end_fingerprint\"",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Capture success vs skip rate",
      "gridPos": { "x": 0, "y": 18, "w": 12, "h": 4 },
      "datasource": { "type": "loki", "uid": "loki_local" },
      "targets": [
        {
          "expr": "sum(count_over_time({app=\"sim-steward\", component=\"simhub-plugin\"} | json | event = \"session_summary_captured\" [$__interval]))",
          "refId": "A",
          "legendFormat": "captured"
        },
        {
          "expr": "sum(count_over_time({app=\"sim-steward\", component=\"simhub-plugin\"} | json | event = \"session_capture_skipped\" [$__interval]))",
          "refId": "B",
          "legendFormat": "skipped"
        }
      ]
    }
  ],
  "time": { "from": "now-7d", "to": "now" }
}
