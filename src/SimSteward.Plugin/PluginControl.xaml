<UserControl x:Class="SimSteward.Plugin.PluginControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <StackPanel Margin="16">
    <TextBlock Text="Sim Steward" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8"/>
    <TextBlock TextWrapping="Wrap" Margin="0,0,0,12" Foreground="#333333">
      HTML dashboard bridge via WebSocket. Bind to SimSteward.* properties in Dash Studio. Dashboard connects to ws://localhost:19847 for live state.
    </TextBlock>
    <Border BorderBrush="#ccc" BorderThickness="1" Padding="10" Background="#f8f8f8" CornerRadius="4">
      <StackPanel>
        <TextBlock Text="WebSocket server" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,6" Foreground="#333333"/>
        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
          <TextBlock Text="Running:" Width="120" VerticalAlignment="Center" Foreground="#333333"/>
          <TextBlock x:Name="WsRunningText" Text="—" VerticalAlignment="Center" Foreground="#333333"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
          <TextBlock Text="Port:" Width="120" VerticalAlignment="Center" Foreground="#333333"/>
          <TextBlock x:Name="WsPortText" Text="—" VerticalAlignment="Center" Foreground="#333333"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
          <TextBlock Text="Connected clients:" Width="120" VerticalAlignment="Center" Foreground="#333333"/>
          <TextBlock x:Name="ClientCountText" Text="0" VerticalAlignment="Center" Foreground="#333333"/>
        </StackPanel>
      </StackPanel>
    </Border>
    <Border BorderBrush="#ccc" BorderThickness="1" Padding="10" Background="#f8f8f8" CornerRadius="4" Margin="0,12,0,0">
      <StackPanel>
        <TextBlock Text="iRacing" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,6" Foreground="#333333"/>
        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
          <TextBlock Text="SDK started:" Width="120" VerticalAlignment="Center" Foreground="#333333"/>
          <TextBlock x:Name="IrsdkStartedText" Text="—" VerticalAlignment="Center" Foreground="#333333"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
          <TextBlock Text="Status:" Width="120" VerticalAlignment="Center" Foreground="#333333"/>
          <TextBlock x:Name="IracingStatusText" Text="Not connected" VerticalAlignment="Center" Foreground="#333333"/>
        </StackPanel>
        <TextBlock x:Name="IracingHelpText" TextWrapping="Wrap" Margin="0,6,0,0" Foreground="#666666" FontSize="11" Visibility="Collapsed"/>
      </StackPanel>
    </Border>
    <Border BorderBrush="#ccc" BorderThickness="1" Padding="10" Background="#f8f8f8" CornerRadius="4" Margin="0,12,0,0">
      <StackPanel>
        <TextBlock Text="Memory Bank" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,6" Foreground="#333333"/>
        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
          <TextBlock Text="Status:" Width="120" VerticalAlignment="Center" Foreground="#333333"/>
          <TextBlock x:Name="MemoryBankStatusText" Text="—" VerticalAlignment="Center" Foreground="#333333"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
          <TextBlock Text="Path:" Width="120" VerticalAlignment="Center" Foreground="#333333"/>
          <TextBlock x:Name="MemoryBankPathText" Text="—" VerticalAlignment="Center" Foreground="#666666" FontSize="10" TextWrapping="Wrap"/>
        </StackPanel>
      </StackPanel>
    </Border>
  </StackPanel>
</UserControl>
